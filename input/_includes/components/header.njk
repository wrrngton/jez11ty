{% set navData = [{url: "/", title: "home"}, {url: "/archive/", title: "archive"}, {url: "/projects/", title: "project"}, {url: "/about/", title: "about"}]%}
<header>

{{ navData.x }}
<div class="container">
  <nav>
    <ul class="capitalize p-0">
      {% for el in navData %}
        <li {% if page.url == el.url %} class="active" {% endif %}><a href="{{ el.url }}">{{ el.title }}</a></li>
      {% endfor %}
    </ul>
  </nav>
</div>
</header>
